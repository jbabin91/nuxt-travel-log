{
  "name": "nuxt-app",
  "version": "0.0.1",
  "private": true,
  "description": "Nuxt app for travel logs",
  "type": "module",
  "scripts": {
    "auth:generate": "pnpm dlx @better-auth/cli@latest generate --config src/lib/auth.ts --output src/lib/db/schema/auth.ts",
    "build": "nuxt build",
    "db:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config ./drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config ./drizzle.config.ts",
    "dev": "concurrently \"pnpm run dev:db\" \"nuxt dev\"",
    "dev:db": "turso dev --db-file local.db",
    "generate": "nuxt generate",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@indoorequal/vue-maplibre-gl": "^8.4.2",
    "@libsql/client": "^0.17.4",
    "@nuxt/eslint": "1.16.0",
    "@nuxt/icon": "2.2.4",
    "@nuxtjs/color-mode": "4.0.1",
    "@pinia/nuxt": "0.11.3",
    "@vee-validate/nuxt": "^4.15.1",
    "@vee-validate/zod": "^4.15.1",
    "better-auth": "~1.5.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "eslint": "^10.5.0",
    "maplibre-gl": "^5.24.0",
    "nanoid": "^5.1.16",
    "nuxt": "^4.4.8",
    "nuxt-csurf": "1.6.5",
    "nuxt-maplibre": "1.2.2",
    "pinia": "^3.0.4",
    "slug": "^11.0.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/vite": "^4.3.1",
    "@types/slug": "^5.0.9",
    "concurrently": "^10.0.3",
    "daisyui": "^5.6.18",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-package-json": "^1.5.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620"
}
